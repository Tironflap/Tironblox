{
  "manifest_version": 3,
  "name": "Roblox Badge Gamerscore",
  "version": "1.0",
  "description": "Shows Badge Gamerscore on profiles, inventory and badge pages",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.roblox.com/*",
    "https://badges.roproxy.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.roblox.com/*"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ]
}