{
  "manifest_version": 3,
  "name": "Tironblox",
  "version": "0.2",
  "version_name": "0.2 (Sphynx)",
  "description": "Automatically shows your Badge Gamerscore on Roblox profiles",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.roblox.com/*",
    "https://badges.roproxy.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.roblox.com/users/*/profile"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ]
}